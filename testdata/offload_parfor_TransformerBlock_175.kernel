PROGRAM("TransformerBlock.cc:175")

OFFLOAD_PARFOR_2D_PARAM(t, f, gate_range, (gate_pre, up_pre, d_ffn_act, d_gate_pre, d_up_pre))

PARAMETERS
        int seq,
        const flexible_rows_matrix<float, 16384, 4096>& gate_pre,
        const flexible_rows_matrix<float, 16384, 4096>& up_pre,
        const flexible_rows_matrix<float, 16384, 4096>& d_ffn_act,
        flexible_rows_matrix<float, 16384, 4096>& d_gate_pre,
        flexible_rows_matrix<float, 16384, 4096>& d_up_pre

BEGIN
const int t = int(gl_GlobalInvocationID.x);
if (t >= rllm_bound_x) return;
const int f = int(gl_GlobalInvocationID.y);
if (f >= rllm_bound_y) return;
        const float g = gate_pre[t, f];
        const float sg = (1.0f / (1.0f +  exp (-g))); // sigma(g)
        const float silu = (g * sg);
        // silu'(g) = sigma(g) * (1 + g * (1 - sigma(g)))
        // Avoids exp(-g)*sigma(g) which gives inf*0=NaN for g < -88 in float32.
        const float dsilu_dg = (sg * (1.0f + (g * (1.0f - sg))));
        d_gate_pre[t, f] = ((d_ffn_act[t, f] * up_pre[t, f]) * dsilu_dg);
        d_up_pre[t, f] = (d_ffn_act[t, f] * silu);

END_PROGRAM