PROGRAM("TransformerBlock.cc:395")

OFFLOAD_PARFOR_2D_TRIANGULAR_PARAM(i, j, seq_len, (d_scores_h, d_attn_concat, V, seq_len, hi))

PARAMETERS
        fixed_size_triangular_matrix<float, 16384, 16384>& d_scores_h,
        const flexible_rows_matrix<float, 16384, 1024>& d_attn_concat,
        const flexible_rows_matrix<float, 16384, 1024>& V,
        int seq_len,
        int hi

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
const int j = int(gl_GlobalInvocationID.y);
if (j >= rllm_bound_y) return;
        {
            float dot = 0.f;
            for (const int d : limit<1024>())
            {
                dot += (d_attn_concat[i, d] * V[j, d]);
            }
            d_scores_h[i, j] = dot;
        }

END_PROGRAM