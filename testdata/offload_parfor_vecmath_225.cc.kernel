PROGRAM("vecmath.cc:225")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A, B1, C1, B2, C2, B3, C3))

PARAMETERS
        const flexible_rows_matrix< float , 16384, 1024>& A,
        const fixed_size_matrix< float16 , 1024, 1024>& B1,
        flexible_rows_matrix< float , 16384, 1024>& C1,
        const fixed_size_matrix< float16 , 1024, 1024>& B2,
        flexible_rows_matrix< float , 16384, 1024>& C2,
        const fixed_size_matrix< float16 , 1024, 1024>& B3,
        flexible_rows_matrix< float , 16384, 1024>& C3

BEGIN
            float sum1 = 0.f;
            float sum2 = 0.f;
            float sum3 = 0.f;
            for (size_t l_idx = 0; l_idx < (1024); ++l_idx)
            {
                const int k = int(l_idx);
                const float a = A[i, k];
                const float term1 = a * B1[j, k];
                OVERFLOW_CHECK_ADD(sum1, term1);
                sum1 += term1;

                const float term2 = a * B2[j, k];
                OVERFLOW_CHECK_ADD(sum2, term2);
                sum2 += term2;

                const float term3 = a * B3[j, k];
                OVERFLOW_CHECK_ADD(sum3, term3);
                sum3 += term3;
            }
            C1[i, j] = (sum1);
            C2[i, j] = (sum2);
            C3[i, j] = (sum3);

END_PROGRAM