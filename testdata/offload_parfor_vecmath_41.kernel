PROGRAM("vecmath.cc:41")

OFFLOAD_PARFOR_1D_PARAM(queue, i, limit<16384>(length), (dst, value))

PARAMETERS
        fixed_size_vector<int, 16384>& dst,
        int value,
        int length

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
        dst[i] = value;

END_PROGRAM