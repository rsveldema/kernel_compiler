PROGRAM("vecmath.cc:92")

OFFLOAD_PARFOR_1D_PARAM(d, limit<1024>(), (src, row, dst))

PARAMETERS
        const flexible_rows_matrix<float, 16384, 1024>& src,
        int row,
        fixed_size_vector<float, 1024>& dst

BEGIN
const int d = int(gl_GlobalInvocationID.x);
if (d >= rllm_bound_x) return;
        dst[d] = src[row, d];

END_PROGRAM