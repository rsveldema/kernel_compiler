PROGRAM("TransformerBlock.cc:95")

OFFLOAD_PARFOR_1D_PARAM(t, limit<16384>(x.num_rows()), (dy, x, dx))

PARAMETERS
        const flexible_rows_matrix<float, 16384, 1024>& dy,
        const flexible_rows_matrix<float, 16384, 1024>& x,
        flexible_rows_matrix<float, 16384, 1024>& dx

BEGIN
        constexpr float eps = 1e-6f;

        float sq = 0.f;
        for (const int i : limit<1024>()) {
            const float value = x[t, i];
            sq += (value * value);
        }

        constexpr float fd = 1024;            
        const float inv = (1.0f /  sqrt (((sq / fd) + eps)));

        // dot = mean(dy · y) = (1/d) * sum_i dy[i] * x[i] * inv
        float dot = 0.f;
        for (const int i : limit<1024>()) {
            dot += ((dy[t, i] * x[t, i]) * inv);
        }

        dot /= fd;

        for (const int i : limit<1024>()) {
            dx[t, i] += (inv * (dy[t, i] - ((x[t, i] * inv) * dot)));
        }

END_PROGRAM