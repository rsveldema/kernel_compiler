PROGRAM("vecmath.cc:342")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A, B, C))

PARAMETERS
        const flexible_rows_matrix<float, 16384, 1024>& A,
        const fixed_size_matrix<float16, 1024, 4096>& B,
        flexible_rows_matrix<float, 16384, 4096>& C

BEGIN
            float sum = 0.f;
            for (int l_idx = 0; l_idx < 1024; ++l_idx)
            {
                const int k = int(l_idx);
                const float term = (A[i, k] * B[k, j]);
                OVERFLOW_CHECK_ADD(sum, term);
                sum += term;
            }
            C[i, j] = sum;

END_PROGRAM