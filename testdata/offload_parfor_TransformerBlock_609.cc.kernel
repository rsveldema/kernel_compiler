PROGRAM("TransformerBlock.cc:609")

OFFLOAD_PARFOR_3D_PARAM(hi, j, d_head, dk_grid, (d_K, d_raw_h, Q, head_scale, seq_len, d_raw_h_rows, d_raw_h_cols))

PARAMETERS
        flexible_rows_matrix<rlmm_float, 16384, 1024>& d_K ,
        const fixed_size_levels_rows_cols_matrix<rlmm_float, 8, 16384, 16384>& d_raw_h ,
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& Q ,
        float head_scale ,
        int seq_len ,
         const int d_raw_h_rows ,
         const int d_raw_h_cols

BEGIN
        {
            const int hi_int = hi;
            const int d = hi_int * 128 + int(d_head);
            const float hs = head_scale;
            float sum_k = 0.f;
            for (const int i : limit<16384>(j, seq_len))
                sum_k += d_raw_h[hi, i, j] * hs * Q[i, d];
            d_K[j, d] = sum_k;
        }

END_PROGRAM