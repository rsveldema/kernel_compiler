PROGRAM("vecmath.cc:504")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A, B, C, k_count))

PARAMETERS
        const flexible_rows_matrix< float , 16384, 1024>& A,
        const flexible_rows_matrix< float , 16384, 1024>& B,
        fixed_size_matrix< float , 1024, 1024>& C,
        int k_count

BEGIN
            float sum = 0.f;
            for (size_t l_idx = 0; l_idx < (k_count); ++l_idx)
            {
                const int k = int(l_idx);
                const float term = A[k, i] * B[k, j];
                OVERFLOW_CHECK_ADD(sum, term);
                sum += term;
            }
            C[i, j] += (sum);

END_PROGRAM