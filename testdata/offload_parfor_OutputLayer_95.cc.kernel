PROGRAM("OutputLayer.cc:95")

OFFLOAD_PARFOR_2D_PARAM(v, d, grid, (delta, h_last, W, V, learning_rate))

PARAMETERS
        const fixed_size_vector< float ,  int >& delta,
        const fixed_size_vector< float , 1024>& h_last,
        fixed_size_matrix< float16 ,  int , 1024>& W,
        fixed_size_matrix< float ,  int , 1024>& V,
        float learning_rate

BEGIN
        const float g =  clamp (delta[v] * h_last[d], -1.000000, 1.000000);
        V[v, d] =  clamp (
            0.900000 * V[v, d] + learning_rate * g, -0.100000, 0.100000
        );
        W[v, d] =  clamp (W[v, d] + V[v, d], -2.000000, 2.000000);

END_PROGRAM