PROGRAM("vecmath.cc:116")

OFFLOAD_PARFOR_2D_PARAM(r, c, grid, (W1, vel1, grad1, W2, vel2, grad2, W3, vel3, grad3, W4, vel4, grad4, lr))

PARAMETERS
        fixed_size_matrix<rlmm_float_small, 1024, 1024>& W1,
        fixed_size_matrix<rlmm_float, 1024, 1024>& vel1,
        const fixed_size_matrix<rlmm_float, 1024, 1024>& grad1,
        fixed_size_matrix<rlmm_float_small, 1024, 1024>& W2,
        fixed_size_matrix<rlmm_float, 1024, 1024>& vel2,
        const fixed_size_matrix<rlmm_float, 1024, 1024>& grad2,
        fixed_size_matrix<rlmm_float_small, 1024, 1024>& W3,
        fixed_size_matrix<rlmm_float, 1024, 1024>& vel3,
        const fixed_size_matrix<rlmm_float, 1024, 1024>& grad3,
        fixed_size_matrix<rlmm_float_small, 1024, 1024>& W4,
        fixed_size_matrix<rlmm_float, 1024, 1024>& vel4,
        const fixed_size_matrix<rlmm_float, 1024, 1024>& grad4,
        float lr

BEGIN
        const float g1 = math::clamp(grad1[r, c], -1.000000, 1.000000);
        vel1[r, c] = math::clamp(
            0.900000 * vel1[r, c] + lr * g1,
            -0.100000,
            0.100000
        );
        W1[r, c] = math::clamp(W1[r, c] + vel1[r, c], -2.000000, 2.000000);

        const float g2 = math::clamp(grad2[r, c], -1.000000, 1.000000);
        vel2[r, c] = math::clamp(
            0.900000 * vel2[r, c] + lr * g2,
            -0.100000,
            0.100000
        );
        W2[r, c] = math::clamp(W2[r, c] + vel2[r, c], -2.000000, 2.000000);

        const float g3 = math::clamp(grad3[r, c], -1.000000, 1.000000);
        vel3[r, c] = math::clamp(
            0.900000 * vel3[r, c] + lr * g3,
            -0.100000,
            0.100000
        );
        W3[r, c] = math::clamp(W3[r, c] + vel3[r, c], -2.000000, 2.000000);

        const float g4 = math::clamp(grad4[r, c], -1.000000, 1.000000);
        vel4[r, c] = math::clamp(
            0.900000 * vel4[r, c] + lr * g4,
            -0.100000,
            0.100000
        );
        W4[r, c] = math::clamp(W4[r, c] + vel4[r, c], -2.000000, 2.000000);

END_PROGRAM