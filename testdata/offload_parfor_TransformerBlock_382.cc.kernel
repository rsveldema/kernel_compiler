PROGRAM("TransformerBlock.cc:382")

OFFLOAD_PARFOR_2D_PARAM(j, d_head, head_grid, (d_K, d_raw_h, Q, hStart, head_scale, seq_len))

PARAMETERS
        flexible_rows_matrix< float , 16384, 1024>& d_K,
        const flexible_rows_cols_matrix< float , 16384, 16384>& d_raw_h,
        const flexible_rows_matrix< float , 16384, 1024>& Q,
         int hStart,
        float head_scale,
        int seq_len

BEGIN
        const int d = int(hStart) + int(d_head);
        float sum_k = 0.f;
        // iterates from j...seq-1 due to causality (scores_mat is upper-triangular); d_raw_h[i, j] is nonzero only for
        // i ≥ j.
        for (const int i : limit<16384>(j, seq_len))
            sum_k += d_raw_h[i, j] * head_scale * Q[i, d];
        d_K[j, d] = sum_k;

END_PROGRAM