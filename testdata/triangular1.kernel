PROGRAM("TransformerBlock.cc:503")

OFFLOAD_PARFOR_2D_TRIANGULAR_PARAM(i, j, seq_len, (d_scores_h, d_raw_h, attn_w_h, seq_len))

PARAMETERS
        const flexible_size_matrix< float , 16384, 16384>& d_scores_h,
        flexible_size_matrix< float , 16384, 16384>& d_raw_h,
        const flexible_size_matrix< float , 16384, 16384>& attn_w_h,
        int seq_len

BEGIN
        {
            float row_dot = 0.f;
            for (const int k : limit<16384>(0, inc(i)))
            {
                row_dot += d_scores_h[i, k] * attn_w_h[i, k];
            }
            d_raw_h[i, j] = attn_w_h[i, j] * (d_scores_h[i, j] - row_dot);
        }

END_PROGRAM