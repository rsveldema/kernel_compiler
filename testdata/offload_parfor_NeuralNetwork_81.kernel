PROGRAM("NeuralNetwork.cc:81")

OFFLOAD_PARFOR_1D_PARAM(d, limit<1024>(), (dh_last, dh, last_pos))

PARAMETERS
        const fixed_size_vector<float, 1024>& dh_last,
        flexible_rows_matrix<float, 16384, 1024>& dh,
        int last_pos

BEGIN
const int d = int(gl_GlobalInvocationID.x);
if (d >= rllm_bound_x) return;
        dh[last_pos, d] = dh_last[d];

END_PROGRAM