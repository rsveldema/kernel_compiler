PROGRAM("TransformerBlock.cc:453")

OFFLOAD_PARFOR_2D_PARAM(i, d_head, head_grid, (d_Q, d_raw_h, K, hStart, head_scale, seq_len))

PARAMETERS
        flexible_rows_matrix<rlmm_float, 16384, 1024>& d_Q,
        const flexible_rows_cols_matrix<rlmm_float, 16384, 16384>& d_raw_h,
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& K,
        EmbeddingDimension hStart,
        float head_scale,
        int seq_len

BEGIN
        const int d = int(hStart) + int(d_head);
        float sum_q = 0.f;
        // iterates from 0...i due to causality (scores_mat is upper-triangular); d_raw_h[i, j] is nonzero only for j ≤
        // i.
        for (const int j : limit<16384>(inc(i)))
            sum_q += d_raw_h[i, j] * head_scale * K[j, d];
        d_Q[i, d] = sum_q;

END_PROGRAM