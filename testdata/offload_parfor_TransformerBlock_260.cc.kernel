PROGRAM("TransformerBlock.cc:260")

OFFLOAD_PARFOR_1D_PARAM(i, limit<16384>(T), (dp, p, dscores))

PARAMETERS
        const flexible_rows_cols_matrix<rlmm_float, 16384, 16384>& dp,
        const flexible_rows_cols_matrix<rlmm_float, 16384, 16384>& p,
        flexible_rows_cols_matrix<rlmm_float, 16384, 16384>& dscores,
        int T

BEGIN
        rlmm_float dot = 0.f;
        for (const int j : limit<16384>(inc(i)))
            dot += dp[i, j] * p[i, j];
        for (const int j : limit<16384>(inc(i)))
            dscores[i, j] += p[i, j] * (dp[i, j] - dot);

END_PROGRAM