PROGRAM("vecmath.cc:400")

OFFLOAD_PARFOR_2D_PARAM(queue, i, j, grid, (A, B, C))

PARAMETERS
        const flexible_rows_matrix<float, 16384, 4096>& A,
        const fixed_size_matrix<float16, 4096, 1024>& B,
        flexible_rows_matrix<float, 16384, 1024>& C

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
const int j = int(gl_GlobalInvocationID.y);
if (j >= rllm_bound_y) return;
            float sum = 0.f;
            for (int l_idx = 0; l_idx < 4096; ++l_idx)
            {
                const int k = int(l_idx);
                const float term = (A[i, k] * B[k, j]);
                OVERFLOW_CHECK_ADD(sum, term);
                sum += term;
            }
            C[i, j] += sum;

END_PROGRAM