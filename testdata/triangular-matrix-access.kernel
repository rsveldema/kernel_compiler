PROGRAM("triangular_access.cc:1")

OFFLOAD_PARFOR_2D_TRIANGULAR_PARAM(i, j, limit<8>(), (tri_in, tri_out))

PARAMETERS
        const fixed_size_triangular_matrix< float, 8, 8>& tri_in,
        fixed_size_triangular_matrix< float, 8, 8>& tri_out

BEGIN
        tri_out[i, j] = tri_in[i, j] + 1.0f;

END_PROGRAM
