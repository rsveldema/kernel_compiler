PROGRAM("TransformerBlock.cc:275")

OFFLOAD_PARFOR_2D_TRIANGULAR_PARAM(i, j, active_seq_len, (attn_concat, attn_w_h, V, active_seq_len, hi))

PARAMETERS
        const fixed_size_triangular_matrix<float, 16384, 16384>& attn_w_h,
        const flexible_rows_matrix<float, 16384, 1024>& V,
        flexible_rows_matrix<float, 16384, 1024>& attn_concat,
        int active_seq_len,
        int hi

BEGIN
        {
            const float w = attn_w_h[i, j];
            for (const int d : limit<1024>())
            {
                attn_concat[i, d] += (w * V[j, d]);
            }
        }

END_PROGRAM