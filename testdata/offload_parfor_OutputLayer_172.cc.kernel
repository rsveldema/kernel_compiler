PROGRAM("OutputLayer.cc:172")

OFFLOAD_PARFOR_1D_PARAM(i, limit<598>(), (values, temp_values, expected_output_token))

PARAMETERS
        fixed_size_vector< float ,  int >& values,
        const fixed_size_vector< float , 2>& temp_values,
         int  expected_output_token

BEGIN
        if (gl_GlobalInvocationID.y != 0u)
            return;
        const float sum_exp = temp_values[1];
        float delta = 0.000167 - values[i] / sum_exp;
        if (i == expected_output_token)
            delta += (1.0f - 0.100000);
        values[i] = delta;

END_PROGRAM