PROGRAM("vecmath.cc:392")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A, B, C))

PARAMETERS
        const flexible_rows_matrix<rlmm_float, 16384, FFDimension>& A,
        const fixed_size_matrix<rlmm_float_small, FFDimension, 1024>& B,
        flexible_rows_matrix<rlmm_float, 16384, 1024>& C

BEGIN
            float sum = 0.f;
            RLLM_OMP_SIMD_REDUCTION_PLUS(sum)
            for (size_t l_idx = 0; l_idx < 4096; ++l_idx)
            {
                const int k = int(l_idx);
                const float term = A[i, k] * B[k, j];
                OVERFLOW_CHECK_ADD(sum, term);
                sum += term;
            }
            C[i, j] += sum;

END_PROGRAM