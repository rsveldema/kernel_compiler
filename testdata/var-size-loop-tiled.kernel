PROGRAM("vecmath.cc:641")
workgroup { x: 8, y: 1, z: 1 }

OFFLOAD_PARFOR_1D_PARAM(i, limit<16384>(active_len), (dst, value, k_count, active_len))

PARAMETERS
        fixed_size_vector<int, 16384>& dst,
        int value,
        int k_count,
        int active_len

BEGIN
        for (int j = 0; j < k_count; j++) {
            dst[i] = value;
        }

END_PROGRAM
