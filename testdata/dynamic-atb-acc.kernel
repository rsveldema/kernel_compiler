PROGRAM("vecmath.cc:900")

OFFLOAD_PARFOR_2D_PARAM(i, j, grid, (A, B, C, k_count))

PARAMETERS
        const fixed_size_matrix< float , 16, 8>& A,
        const fixed_size_matrix< float , 16, 8>& B,
        fixed_size_matrix< float , 8, 8>& C,
        int k_count

BEGIN
            float sum = 0.f;
            for (size_t l_idx = 0; l_idx < (k_count); ++l_idx)
            {
                const int k = int(l_idx);
                const float term = (A[k, i] * B[k, j]);
                OVERFLOW_CHECK_ADD(sum, term);
                sum += term;
            }
            C[i, j] += (sum);

END_PROGRAM
