PROGRAM("TransformerBlock.cc:358")

OFFLOAD_PARFOR_2D_TRIANGULAR_PARAM(i, j, seq_len, (d_V, attn_w_h, d_attn_concat, seq_len, hStart))

PARAMETERS
        flexible_rows_matrix<float, 16384, 1024>& d_V,
        const fixed_size_triangular_matrix<float, 16384, 16384>& attn_w_h,
        const flexible_rows_matrix<float, 16384, 1024>& d_attn_concat,
        int seq_len,
        int hStart

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
const int j = int(gl_GlobalInvocationID.y);
if (j >= rllm_bound_y) return;
        {
            const float w = attn_w_h[i, j];
            for (const int d_head : limit<128>())
            {
                const int d = (hStart + int(d_head));
                d_V[j, d] += (w * d_attn_concat[i, d]);
            }
        }

END_PROGRAM