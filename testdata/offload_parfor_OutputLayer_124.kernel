PROGRAM("OutputLayer.cc:124")

OFFLOAD_PARFOR_1D_PARAM(queue, i, limit<620>(), (inputs, values, temp_values))

PARAMETERS
        const fixed_size_vector<float, 620>& inputs,
        fixed_size_vector<float, 620>& values,
        fixed_size_vector<float, 2>& temp_values

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
        {
            const float max_val = temp_values[0];
            float exp_value = exp((inputs[i] - max_val));
            values[i] = exp_value;

            atomicAdd(temp_values[1], exp_value);
        }

END_PROGRAM