PROGRAM("TransformerBlock.cc:188")

OFFLOAD_PARFOR_1D_PARAM(t, limit<16384>(x.num_rows()), (dy, x, dx))

PARAMETERS
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& dy,
        const flexible_rows_matrix<rlmm_float, 16384, 1024>& x,
        flexible_rows_matrix<rlmm_float, 16384, 1024>& dx

BEGIN
        constexpr float eps = 1e-6f;
        constexpr float fd = 1024;

        rlmm_float sq = 0.f;
        for (const int i : limit<1024>())
            sq += x[t, i] * x[t, i];
        const rlmm_float inv = 1.0f / std::sqrt(sq / fd + eps);

        // dot = mean(dy · y) = (1/d) * sum_i dy[i] * x[i] * inv
        rlmm_float dot = 0.f;
        for (const int i : limit<1024>())
            dot += dy[t, i] * x[t, i] * inv;
        dot /= fd;

        for (const int i : limit<1024>())
            dx[t, i] += inv * (dy[t, i] - x[t, i] * inv * dot);

END_PROGRAM