PROGRAM("vecmath.cc:193")

OFFLOAD_PARFOR_2D_PARAM(r, c, grid, (W, vel, grad, lr))

PARAMETERS
        fixed_size_matrix< float16 , 1024, FFDimension>& W,
        fixed_size_matrix< float , 1024, FFDimension>& vel,
        const fixed_size_matrix< float , 1024, FFDimension>& grad,
        float lr

BEGIN
        const float g =  clamp (grad[r, c], -1.000000, 1.000000);
        vel[r, c] =  clamp (
            0.900000 * vel[r, c] + lr * g,
            -0.100000,
            0.100000
        );
        W[r, c] =  clamp (
            W[r, c] + vel[r, c],
            -2.000000,
            2.000000
        );

END_PROGRAM