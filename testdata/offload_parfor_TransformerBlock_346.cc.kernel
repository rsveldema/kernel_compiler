PROGRAM("TransformerBlock.cc:346")

OFFLOAD_PARFOR_2D_PARAM(hi, i, softmax_grid, (attn_w, active_seq_len))

PARAMETERS
        flexible_rows_cols_levels_matrix<rlmm_float, 8, 16384, 16384>& attn_w ,
        int active_seq_len;

BEGIN
        {
            rlmm_float max_val = attn_w[hi, i, 0];
            for (int j = 1; j <= i; ++j)
                max_val = math::max(max_val, attn_w[hi, i, j]);
            rlmm_float sum_exp = 0.f;
            for (int j = 0; j <= i; ++j)
            {
                attn_w[hi, i, j] = std::exp(attn_w[hi, i, j] - max_val);
                sum_exp += attn_w[hi, i, j];
            }
            const rlmm_float inv = 1.0f / sum_exp;
            for (int j = 0; j <= i; ++j)
                attn_w[hi, i, j] *= inv;
            for (int j = i + 1; j < active_seq_len; ++j)
                attn_w[hi, i, j] = 0.f;
        }

END_PROGRAM