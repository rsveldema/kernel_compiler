PROGRAM("vecmath.cc:53")

OFFLOAD_PARFOR_1D_PARAM(i, limit<16384>(length), (dst, value))

PARAMETERS
        fixed_size_vector<float, 16384>& dst,
        float value,
        int length

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
        dst[i] = value;

END_PROGRAM