PROGRAM("OutputLayer.cc:143")

OFFLOAD_PARFOR_1D_PARAM(queue, i, limit<620>(), (values, temp_values, expected_output_token))

PARAMETERS
        fixed_size_vector<float, 620>& values,
        const fixed_size_vector<float, 2>& temp_values,
        int expected_output_token

BEGIN
const int i = int(gl_GlobalInvocationID.x);
if (i >= rllm_bound_x) return;
        const float sum_exp = temp_values[1];
        float delta = (0.000161 - (values[i] / sum_exp));
        if (i == expected_output_token)
            delta += (1.0f - 0.100000);
        values[i] = delta;

END_PROGRAM