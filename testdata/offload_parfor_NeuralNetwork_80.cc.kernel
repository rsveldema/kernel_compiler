PROGRAM("NeuralNetwork.cc:80")

OFFLOAD_PARFOR_1D_PARAM(d, limit<1024>(), (dh_last, dh, last_pos))

PARAMETERS
        const fixed_size_vector<rlmm_float, 1024>& dh_last,
        flexible_rows_matrix<rlmm_float, 16384, 1024>& dh,
        int last_pos

BEGIN
        dh[last_pos, d] = dh_last[d];

END_PROGRAM