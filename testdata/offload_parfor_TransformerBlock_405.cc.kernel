PROGRAM("TransformerBlock.cc:405")

OFFLOAD_PARFOR_3D_TRIANGULAR_PARAM(hi, i, j, (8), seq_len, (d_V, attn_w, d_attn_concat, seq_len))

PARAMETERS
        flexible_rows_matrix< float , 16384, 1024>& d_V ,
        const flexible_rows_cols_levels_matrix< float , 8, 16384, 16384>& attn_w ,
        const flexible_rows_matrix< float , 16384, 1024>& d_attn_concat ,
        const int seq_len

BEGIN
        {
            const int hi_int = (hi);
            const int h_start = hi_int * 128;
            const int h_end = (hi_int + 1) * 128;
            const float w = attn_w[hi, i, j];
            for (int d = h_start; d < h_end; ++d)
                atomicAdd((d_V[j, d]), (w * d_attn_concat[i, d]));
        }

END_PROGRAM