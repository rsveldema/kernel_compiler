PROGRAM("OutputLayer.cc:60")

OFFLOAD_PARFOR_1D_PARAM(v, limit<598>(), (h_last, W, inputs))

PARAMETERS
        const fixed_size_vector< float , 1024>& h_last,
        const fixed_size_matrix< float16 ,  int , 1024>& W,
        fixed_size_vector< float ,  int >& inputs

BEGIN
        float sum = 0.f;
        for (const int d : limit<1024>())
            sum += h_last[d] * W[v, d];
        inputs[v] = sum;

END_PROGRAM